# MySQL Root credentials (used for administrative operations)
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=your_root_password

# MySQL Clone user credentials (used for clone plugin operations)
MYSQL_CLONE_USER=clone_user
MYSQL_CLONE_PASSWORD=your_clone_password

# MySQL Replication user credentials (used for replication channel)
MYSQL_REPL_USER=repl_user
MYSQL_REPL_PASSWORD=your_repl_password

